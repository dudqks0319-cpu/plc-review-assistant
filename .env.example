# Optional: enable server-side Codex app-server requirement normalization.
# Keep tokens server-side only. Never expose Codex or OpenAI secrets to browser JavaScript.
PLC_CODEX_REQUIREMENT_NORMALIZER=off

# Optional path to the Codex executable. Defaults to "codex".
PLC_CODEX_BIN=codex

# Optional model override for Codex app-server thread/start.
PLC_CODEX_MODEL=

# Optional timeout for app-server normalization.
PLC_CODEX_TIMEOUT_MS=20000

# Optional: pass a Codex access token to child process environment.
# Prefer a secret manager or shell environment; do not commit a real token here.
CODEX_ACCESS_TOKEN=
